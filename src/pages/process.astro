---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';

const steps = [
  { number: "01", title: "Consultation", description: "We sit down to discuss your health history, current concerns, and wellness goals. This is a time for us to listen to your story." },
  { number: "02", title: "INSiGHT Scans", description: "We use non-invasive technology (sEMG, Thermal, HRV) to measure nervous system stress and function objectively." },
  { number: "03", title: "Examination", description: "A physical assessment of spinal alignment and tension. In most cases, you'll receive your first adjustment during this visit." },
  { number: "04", title: "Report of Findings", description: "We review your results together and present a personalized care plan tailored to your specific neurological needs." }
];
---

<BaseLayout
  title="What to Expect | Your First Visit | Trinity Life Chiropractic Allen TX"
  description="Learn what to expect at your first visit to Trinity Life Chiropractic. Our thorough 45-60 minute process includes consultation, INSiGHT scans, examination, and a personalized care plan."
  ogImage="/assets/og-process.png"
>
  <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'What to Expect' }]} />

  <section class="py-28 bg-brand-plum text-white relative overflow-hidden mt-24">
    <div class="absolute inset-0 overflow-hidden opacity-10 pointer-events-none">
      <div class="absolute -top-32 -left-32 w-[500px] h-[500px] rounded-full bg-white blur-[120px]"></div>
      <div class="absolute -bottom-32 -right-32 w-[500px] h-[500px] rounded-full bg-brand-gold blur-[120px]"></div>
    </div>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;" />

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-20">
        <span class="text-brand-gold-light font-bold tracking-[0.2em] uppercase text-xs">New Patient Journey</span>
        <h1 class="mt-4 font-display text-4xl font-medium text-white sm:text-5xl tracking-tight">Your First Visit Explained</h1>
        <p class="mt-5 text-lg text-white/60 leading-relaxed">Our thorough 45-60 minute initial process ensures we get to the root cause of your health concerns.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {steps.map((step) => (
          <div class="relative group">
            <div class="bg-white/8 backdrop-blur-sm border border-white/8 p-8 rounded-2xl h-full hover:bg-white/12 transition-all duration-300 hover:border-white/15">
              <div class="font-display text-5xl font-medium text-white/6 absolute top-4 right-6 group-hover:text-white/10 transition-colors">{step.number}</div>
              <h3 class="font-display text-xl font-semibold text-white mb-3">{step.title}</h3>
              <p class="text-white/55 leading-relaxed text-sm">{step.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16 text-center">
        <div class="bg-white/5 backdrop-blur-md inline-block rounded-2xl p-10 max-w-2xl border border-white/8">
          <h4 class="font-display text-2xl font-medium text-white mb-2">Ready to get started?</h4>
          <p class="text-white/60 mb-7 leading-relaxed">Book your initial exam online. Appointments are highly recommended as we are closed on Wednesdays and weekends.</p>
          <a href="https://trinitylifechiro.janeapp.com?utm_source=process_page&utm_medium=cta&utm_campaign=process_cta" target="_blank" rel="noopener noreferrer" data-track="book-appointment" class="inline-block bg-brand-gold hover:bg-brand-gold-dark text-white px-8 py-3.5 rounded-full font-bold transition-all hover:scale-[1.03] shadow-lg shadow-black/20 tracking-wide">
            Schedule Initial Exam
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
