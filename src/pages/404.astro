---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Trinity Life Chiropractic"
  description="The page you're looking for doesn't exist. Navigate back to Trinity Life Chiropractic to learn about our family chiropractic services in Allen, TX."
  noindex={true}
>
  <section class="flex min-h-[70vh] items-center justify-center px-4 py-24">
    <div class="text-center max-w-lg">
      <p class="font-display text-8xl md:text-9xl font-bold text-brand-plum/20 leading-none mb-4">
        404
      </p>
      <h1 class="font-display text-3xl md:text-4xl font-bold text-gray-900 mb-4 tracking-tight">
        Page Not Found
      </h1>
      <p class="text-lg text-gray-600 mb-10">
        Sorry, we couldn't find the page you were looking for. It may have been moved or no longer exists.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-lg bg-brand-plum px-6 py-3 text-white font-semibold shadow-md transition hover:bg-brand-plum-dark"
        >
          Back to Home
        </a>
        <a
          href="/services"
          class="inline-flex items-center justify-center rounded-lg border-2 border-brand-gold px-6 py-3 text-brand-gold font-semibold transition hover:bg-brand-gold hover:text-white"
        >
          View Services
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
