---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map(entry => ({
    params: { location: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;

const servicesOffered = [
  { name: 'Pregnancy Chiropractic (Webster Technique)', slug: '/pregnancy-chiropractic-care', desc: 'Specialized prenatal care for a healthier pregnancy and better birth outcomes.' },
  { name: 'Pediatric Chiropractic', slug: '/pediatric-chiropractor-services', desc: 'Gentle, neurological care for infants, children, and teens.' },
  { name: 'Family Chiropractic', slug: '/family-chiropractic', desc: 'Whole-family wellness care for every stage of life.' },
  { name: 'Nervous System / INSiGHT Scans', slug: '/nervous-system-care', desc: 'Objective nervous system assessment with NASA-certified technology.' },
  { name: 'Colic & Reflux Relief', slug: '/colic-reflux-relief', desc: 'Drug-free relief for infant digestive distress.' },
  { name: 'ADHD & Sensory Support', slug: '/adhd-sensory-processing', desc: 'Neurological support for focus, regulation, and calm.' },
];

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: data.faqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout
  title={data.metaTitle}
  description={data.metaDescription}
  ogImage={data.heroImage}
  structuredData={faqStructuredData}
>
  <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Service Areas', href: '/locations' }, { name: `${data.city}, ${data.state}` }]} />

  <!-- 1. HERO -->
  <div class="relative min-h-[60vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${data.heroImage}')`}>
      <div class="absolute inset-0 bg-gradient-to-r from-brand-plum-dark/95 to-brand-plum/75" />
    </div>
    <img src={data.heroImage} alt={`Chiropractor serving ${data.city}, ${data.state} — Trinity Life Chiropractic`} class="sr-only" loading="eager" />
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pt-40 pb-20">
      <div class="max-w-2xl text-white animate-fade-in-up">
        <div class="flex items-center gap-2 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span class="text-brand-gold font-bold tracking-widest uppercase text-sm">Serving {data.city}, {data.state}</span>
        </div>
        <h1 class="font-display text-4xl md:text-6xl font-bold mb-6 leading-tight tracking-tight">{data.heroHeadline}</h1>
        <p class="text-xl md:text-2xl text-white/80 font-light mb-10 leading-relaxed">{data.heroSubheadline}</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="https://trinitylifechiro.janeapp.com?utm_source=location_page&utm_medium=cta&utm_campaign=location_cta" target="_blank" rel="noopener noreferrer" data-track="book-appointment" class="bg-brand-gold text-white px-8 py-4 rounded-full font-bold hover:bg-brand-gold-dark transition-colors shadow-lg flex items-center justify-center gap-2">
            Schedule Your Visit <span>&rarr;</span>
          </a>
          <a href="tel:2145097744" class="bg-white/10 backdrop-blur-md border border-white/20 text-white px-8 py-4 rounded-full font-bold hover:bg-white/20 transition-colors text-center flex items-center justify-center gap-2">
            (214) 509-7744
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- 2. INTRO / STATS -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <div class="lg:col-span-3">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-plum mb-6 tracking-tight">{data.introTitle}</h2>
          <p class="text-lg text-gray-600 leading-relaxed mb-8">{data.introText}</p>
          <div class="flex items-center gap-4">
            <img src="/assets/images/dr-obrien-smiling-patient-care.webp" alt="Dr. Colton O'Brien" class="w-16 h-16 rounded-full object-cover border-2 border-brand-gold" width="64" height="64" loading="lazy" />
            <div>
              <p class="font-bold text-gray-900">Dr. Colton O'Brien, D.C.</p>
              <p class="text-sm text-gray-500">Webster Technique Certified | ICPA Member</p>
            </div>
          </div>
        </div>
        <div class="lg:col-span-2 grid grid-cols-2 gap-4">
          {data.introHighlights.map((stat) => (
            <div class="bg-brand-cream/60 p-6 rounded-2xl text-center border border-gray-100">
              <p class="text-2xl md:text-3xl font-bold text-brand-plum">{stat.value}</p>
              <p class="text-sm text-gray-500 mt-1">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 3. WHY CHOOSE -->
  <section class="py-20 bg-brand-cream/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-brand-gold font-bold tracking-widest uppercase text-sm mb-2 block">Why Choose Trinity Life</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-plum mb-4 tracking-tight">{data.whyChooseTitle}</h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">{data.whyChooseText}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {data.whyChooseReasons.map((reason) => (
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="w-10 h-10 bg-brand-plum/10 rounded-full flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-plum" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3 class="font-display text-lg font-bold text-gray-900 mb-2">{reason.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{reason.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. SERVICES INTERNAL LINKS -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-brand-gold font-bold tracking-widest uppercase text-sm mb-2 block">Our Services</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-plum mb-4 tracking-tight">
          Chiropractic Services Available to {data.city} Families
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          Every service we offer is available to families from {data.city}. Click to learn more about each area of care.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {servicesOffered.map((service) => (
          <a href={service.slug} class="group bg-brand-cream/40 p-8 rounded-2xl border border-gray-100 hover:border-brand-gold hover:shadow-lg transition-all">
            <h3 class="font-display text-lg font-bold text-gray-900 mb-2 group-hover:text-brand-plum transition-colors">{service.name}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{service.desc}</p>
            <span class="inline-flex items-center text-brand-gold text-sm font-bold mt-4 group-hover:gap-2 transition-all">
              Learn More <span class="ml-1">&rarr;</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. COMMUNITY -->
  <section class="py-20 bg-brand-plum text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 32px 32px;" />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-brand-gold font-bold tracking-widest uppercase text-sm mb-2 block">Community</span>
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6 tracking-tight">{data.communityTitle}</h2>
          <p class="text-white/70 text-lg leading-relaxed mb-8">{data.communityText}</p>
          <ul class="space-y-4">
            {data.communityDetails.map((detail) => (
              <li class="flex items-start">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-gold mr-3 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <span class="text-white/80">{detail}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="relative rounded-3xl overflow-hidden shadow-2xl">
          <img src="/assets/images/chiropractor-patient-high-five.webp" alt={`Trinity Life Chiropractic serving ${data.city}, ${data.state} families with neurological chiropractic care`} class="w-full h-full object-cover" width="800" height="600" loading="lazy" />
          <div class="absolute inset-0 bg-brand-plum/10" />
        </div>
      </div>
    </div>
  </section>

  <!-- 6. DIRECTIONS & MAP -->
  <section class="py-20 bg-brand-cream/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-brand-gold font-bold tracking-widest uppercase text-sm mb-2 block">Directions</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-plum mb-4 tracking-tight">{data.directionsTitle}</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">{data.directionsText}</p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div class="space-y-8">
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-2xl border border-gray-100 text-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-brand-gold mx-auto mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
              <p class="text-2xl font-bold text-brand-plum">{data.driveTime}</p>
              <p class="text-sm text-gray-500">Drive Time</p>
            </div>
            <div class="bg-white p-6 rounded-2xl border border-gray-100 text-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-brand-gold mx-auto mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
              <p class="text-2xl font-bold text-brand-plum">{data.driveDistance}</p>
              <p class="text-sm text-gray-500">Distance</p>
            </div>
          </div>
          <div class="bg-white p-8 rounded-2xl border border-gray-100">
            <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-plum" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
              Step-by-Step Directions
            </h3>
            <ol class="space-y-3">
              {data.directionsSteps.map((step, idx) => (
                <li class="flex items-start">
                  <span class="flex-shrink-0 w-6 h-6 bg-brand-plum text-white rounded-full flex items-center justify-center text-xs font-bold mr-3 mt-0.5">{idx + 1}</span>
                  <span class="text-gray-600">{step}</span>
                </li>
              ))}
            </ol>
          </div>
          <div class="bg-white p-8 rounded-2xl border border-gray-100">
            <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Nearby Landmarks
            </h3>
            <ul class="space-y-2">
              {data.nearbyLandmarks.map((landmark) => (
                <li class="flex items-center text-gray-600">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full mr-3 flex-shrink-0" />
                  {landmark}
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="space-y-6">
          <div class="relative h-80 rounded-2xl overflow-hidden shadow-lg border border-gray-200">
            <iframe
              width="100%"
              height="100%"
              style="border:0"
              loading="lazy"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d71540.07736878887!2d-96.67808302184342!3d33.110987609646465!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x864c17f2bccf1899%3A0x628efbab75b36acd!2sTrinity%20Life%20Chiropractic!5e0!3m2!1sen!2sus!4v1774877528801!5m2!1sen!2sus"
              title={`Map - ${data.city} to Trinity Life Chiropractic`}
            ></iframe>
          </div>
          <div class="bg-brand-plum p-8 rounded-2xl text-white">
            <h3 class="font-display text-xl font-bold mb-6">Office Information</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-gold flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <div>
                  <p class="font-bold">Address</p>
                  <p class="text-white/70">301 N Allen Dr, Allen, TX 75013</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-gold flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <div>
                  <p class="font-bold">Phone</p>
                  <a href="tel:2145097744" class="text-white/70 hover:text-white transition-colors">(214) 509-7744</a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-gold flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <div>
                  <p class="font-bold mb-2">Hours</p>
                  <div class="text-white/70 text-sm space-y-1">
                    <div class="flex justify-between gap-8"><span>Mon</span><span>9 AM – 6 PM</span></div>
                    <div class="flex justify-between gap-8"><span>Tue</span><span>9 AM – 6 PM</span></div>
                    <div class="flex justify-between gap-8"><span>Wed</span><span class="text-brand-gold">Closed</span></div>
                    <div class="flex justify-between gap-8"><span>Thu</span><span>8 AM – 6 PM</span></div>
                    <div class="flex justify-between gap-8"><span>Fri</span><span>9 AM – 1 PM</span></div>
                    <div class="flex justify-between gap-8"><span>Sat-Sun</span><span class="text-brand-gold">Closed</span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. TESTIMONIALS -->
  <section class="py-20 bg-brand-gold/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-brand-gold font-bold tracking-widest uppercase text-sm mb-2 block">Testimonials</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-plum tracking-tight">What {data.city} Families Say</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {data.testimonials.map((testimonial) => (
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
            <div class="flex mb-4 text-brand-gold">
              {[...Array(5)].map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-current" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ))}
            </div>
            <p class="text-gray-700 italic leading-relaxed mb-6">&ldquo;{testimonial.text}&rdquo;</p>
            <div>
              <p class="font-bold text-gray-900">{testimonial.author}</p>
              <p class="text-sm text-brand-gold">{testimonial.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. FAQ -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-brand-gold font-bold tracking-widest uppercase text-sm mb-2 block">FAQ</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-plum mb-4 tracking-tight">Questions from {data.city} Families</h2>
        <p class="text-lg text-gray-600">Common questions we hear from families in {data.city} about visiting our Allen office.</p>
      </div>
      <div class="space-y-4">
        {data.faqs.map((faq) => (
          <details class="group border border-gray-200 rounded-2xl overflow-hidden bg-white">
            <summary class="flex justify-between items-center w-full p-6 cursor-pointer hover:bg-gray-50 transition-colors list-none [&::-webkit-details-marker]:hidden">
              <span class="font-bold text-gray-800 text-lg pr-4">{faq.question}</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-400 group-open:text-brand-gold group-open:rotate-180 transition-transform flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="p-6 pt-0 text-gray-600 leading-relaxed border-t border-gray-100">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 9. NEARBY AREAS -->
  <section class="py-16 bg-brand-cream/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-display text-2xl font-bold text-brand-plum mb-2 tracking-tight">Also Serving Nearby Communities</h2>
        <p class="text-gray-600">We proudly serve families from across the Collin County and North Texas area.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-4">
        {data.nearbyAreas.map((area) => (
          <a href={`/${area.slug}`} class="bg-white px-6 py-3 rounded-full border border-gray-200 text-brand-plum font-bold hover:border-brand-gold hover:bg-brand-gold/5 transition-all">
            {area.name}, TX
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 10. FINAL CTA -->
  <section class="py-20 bg-brand-plum text-white text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 32px 32px;" />
    <div class="max-w-3xl mx-auto px-4 relative z-10">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-6 tracking-tight">Ready to Experience Trinity Life?</h2>
      <p class="text-xl text-white/70 mb-4">{data.city} families — we'd love to welcome you to our village.</p>
      <p class="text-white/50 mb-10">301 N Allen Dr, Allen, TX 75013 | Just {data.driveTime} from {data.city}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://trinitylifechiro.janeapp.com?utm_source=location_page&utm_medium=cta&utm_campaign=location_final_cta" target="_blank" rel="noopener noreferrer" data-track="book-appointment" class="inline-flex items-center justify-center bg-brand-gold text-white px-10 py-5 rounded-full font-bold text-lg hover:bg-brand-gold-dark transition-colors shadow-2xl transform hover:-translate-y-1">
          Schedule Your Visit
        </a>
        <a href="tel:2145097744" class="inline-flex items-center justify-center bg-white/10 backdrop-blur-md border border-white/20 text-white px-10 py-5 rounded-full font-bold text-lg hover:bg-white/20 transition-colors">
          Call (214) 509-7744
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
